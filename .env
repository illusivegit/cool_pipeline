# ============================================================================
# Single source of truth — consumed by Docker Compose, Makefile, and scripts.
# ============================================================================

# --- Image versions (pinned) ------------------------------------------------
FLASK_IMAGE=python:3.11-slim
NGINX_IMAGE=nginx:alpine
OTEL_COLLECTOR_IMAGE=otel/opentelemetry-collector-contrib:0.96.0
PROMETHEUS_IMAGE=prom/prometheus:v2.48.1
TEMPO_IMAGE=grafana/tempo:2.3.1
LOKI_IMAGE=grafana/loki:2.9.3
GRAFANA_IMAGE=grafana/grafana:10.2.3
ALERTMANAGER_IMAGE=prom/alertmanager:v0.27.0
NODE_EXPORTER_IMAGE=prom/node-exporter:v1.7.0
PROMTAIL_IMAGE=grafana/promtail:2.9.3
NGINX_EXPORTER_IMAGE=nginx/nginx-prometheus-exporter:1.1
CADVISOR_IMAGE=gcr.io/cadvisor/cadvisor:v0.49.1

# --- CORS / Security ---------------------------------------------------------
ALLOWED_ORIGIN=http://localhost:8080

# --- Ports -------------------------------------------------------------------
FRONTEND_PORT=8080
BACKEND_PORT=5000
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
TEMPO_PORT=3200
LOKI_PORT=3100
ALERTMANAGER_PORT=9093
NODE_EXPORTER_PORT=9100
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318

# --- Retention ---------------------------------------------------------------
PROMETHEUS_RETENTION=15d
TEMPO_RETENTION=72h
LOKI_RETENTION=168h

# --- Alerting (optional — requires .env.secrets) ----------------------------
ENABLE_ALERTING=true
SMTP_RELAYHOST=[smtp.mail.yahoo.com]:587
SMTP_FROM=walidahmm@yahoo.com

# --- Project -----------------------------------------------------------------
COMPOSE_PROJECT_NAME=lab
ENVIRONMENT=reference
