    {
      "title": "Scrape Targets Status",
      "type": "table",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 65 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "id": 22,
      "fieldConfig": {
